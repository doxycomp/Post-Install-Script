  "winsettings": {
    "Power": [
      { "id": "set_powerplan_high", "name": "Energiesparplan: Höchstleistung", "commands": ["powercfg /setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c"], "on_error": ["powercfg -duplicatescheme 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c"] },
      { "id": "set_powerplan_low", "name": "Energiesparplan: Energie sparen", "commands": ["powercfg /setactive a1841308-3541-4fab-bc81-f71556f20b4a"], "on_error": ["powercfg -duplicatescheme a1841308-3541-4fab-bc81-f71556f20b4a"]},
      { "id": "set_powerplan_balanced", "name": "Energiesparplan: Ausbalanciert", "commands": ["powercfg /setactive 381b4222-f694-41f0-9685-ff5bb260df2e"], "on_error": ["powercfg -duplicatescheme 381b4222-f694-41f0-9685-ff5bb260df2e"]},
      { "id": "set_no_sleep", "name": "Standby-Timeout deaktivieren", "commands": ["powercfg /change standby-timeout-ac 0"] },
      { "id": "set_no_hibernate", "name": "Ruhezustand deaktivieren", "commands": ["powercfg /hibernate off"] }
    ],
    "Gaming": [
      { "id": "set_game_mode", "name": "Windows Game Mode aktivieren",
        "commands": ["reg add \"HKCU\\Software\\Microsoft\\GameBar\" /v AutoGameModeEnabled /t REG_DWORD /d 1 /f"] },
      { "id": "set_gpu_scheduling", "name": "Hardwarebeschleunigte GPU-Planung",
        "commands": ["reg add \"HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers\" /v HwSchMode /t REG_DWORD /d 2 /f"] }
    ],
    "Privacy": [
      { "id": "set_telemetry_off", "name": "Telemetrie reduzieren",
        "commands": ["reg add \"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection\" /v AllowTelemetry /t REG_DWORD /d 0 /f"] },
      { "id": "set_advertising_id_off", "name": "Werbe-ID deaktivieren",
        "commands": ["reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\AdvertisingInfo\" /v Enabled /t REG_DWORD /d 0 /f"] }
    ],
    "Explorer": [
      { "id": "set_file_extensions", "name": "Dateiendungen anzeigen",
        "commands": ["reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\" /v HideFileExt /t REG_DWORD /d 0 /f"] },
      { "id": "set_hidden_files", "name": "Versteckte Dateien anzeigen",
        "commands": ["reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\" /v Hidden /t REG_DWORD /d 1 /f"] },
      { "id": "set_dark_mode", "name": "Windows Dark Mode",
        "commands": [
          "reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize\" /v AppsUseLightTheme /t REG_DWORD /d 0 /f",
          "reg add \"HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize\" /v SystemUsesLightTheme /t REG_DWORD /d 0 /f"
        ] }
    ]
  },
